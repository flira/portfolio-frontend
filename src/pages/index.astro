---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
---

<BaseLayout title="Portfolio - Home">
  <HeroSection 
    title="Modern Portfolio" 
    subtitle="Built with Astro.js, Lit components, SCSS, and accessibility in mind"
  />
  
  <div class="container">
    <!-- Static content showing the tech stack -->
    <section class="welcome-section">
      <div class="welcome-card" role="article" aria-labelledby="welcome-title">
        <h2 id="welcome-title">Welcome to the Future of Web Development</h2>
        <p>This portfolio demonstrates modern web technologies working together: Astro for static site generation, Lit for interactive components, SCSS for styling, and comprehensive accessibility testing.</p>
        <p><strong>Note:</strong> Lit components are ready for interactive features and are fully tested with Vitest.</p>
      </div>
    </section>

    <section class="features">
      <h2>Technology Stack</h2>
      <div class="features-grid">
        <div class="feature-card">
          <h3>🚀 Astro.js</h3>
          <p>Modern static site generator with island architecture</p>
        </div>
        <div class="feature-card">
          <h3>💡 Lit Components</h3>
          <p>Lightweight web components for interactive elements</p>
        </div>
        <div class="feature-card">
          <h3>🎨 SCSS + CSS Modules</h3>
          <p>Powerful styling with scoped CSS and preprocessor features</p>
        </div>
        <div class="feature-card">
          <h3>♿ Accessibility First</h3>
          <p>Built with axe-core, lighthouse, and pa11y testing</p>
        </div>
        <div class="feature-card">
          <h3>🧪 Vitest Testing</h3>
          <p>Modern testing framework for components and accessibility</p>
        </div>
        <div class="feature-card">
          <h3>⚡ Performance</h3>
          <p>Optimized builds with minimal JavaScript footprint</p>
        </div>
      </div>
    </section>

    <section class="implementation-notes">
      <h2>Implementation Highlights</h2>
      <div class="highlights-grid">
        <div class="highlight">
          <h3>✅ Complete Project Setup</h3>
          <ul>
            <li>Astro.js with Lit integration configured</li>
            <li>SCSS preprocessing with shared variables</li>
            <li>TypeScript for type safety</li>
            <li>Vitest testing framework</li>
          </ul>
        </div>
        <div class="highlight">
          <h3>♿ Accessibility Ready</h3>
          <ul>
            <li>Semantic HTML structure</li>
            <li>ARIA labels and roles</li>
            <li>Keyboard navigation support</li>
            <li>axe-core integration for testing</li>
          </ul>
        </div>
        <div class="highlight">
          <h3>🔧 Development Tools</h3>
          <ul>
            <li>Hot module replacement</li>
            <li>TypeScript checking</li>
            <li>Component testing</li>
            <li>Build optimization</li>
          </ul>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style lang="scss">
  @use '../styles/variables' as *;

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: $spacing-8 $spacing-4;
  }

  .welcome-section {
    margin: $spacing-12 0;
  }

  .welcome-card {
    background: white;
    border-radius: $border-radius-lg;
    padding: $spacing-8;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    border: 1px solid $gray-200;
    margin: $spacing-6 0;

    h2 {
      font-size: $font-size-2xl;
      font-weight: 600;
      color: $text-color;
      margin: 0 0 $spacing-4 0;
    }

    p {
      color: $gray-600;
      line-height: 1.6;
      margin: 0;
    }

    @media (min-width: $breakpoint-md) {
      padding: $spacing-10;

      h2 {
        font-size: $font-size-3xl;
      }
    }
  }

  #interactive-demo {
    margin: $spacing-12 0;
    padding: $spacing-6;
    background: $gray-50;
    border-radius: $border-radius-lg;
    border: 2px dashed $gray-300;

    p {
      color: $gray-700;
      margin-bottom: $spacing-4;
    }
  }

  .implementation-notes {
    margin-top: $spacing-16;
  }

  .implementation-notes h2 {
    text-align: center;
    font-size: $font-size-3xl;
    margin-bottom: $spacing-8;
    color: $text-color;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: $spacing-6;
    margin-top: $spacing-8;
  }

  .highlight {
    background: white;
    padding: $spacing-6;
    border-radius: $border-radius-lg;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    border-left: 4px solid $primary-color;

    h3 {
      font-size: $font-size-lg;
      margin: 0 0 $spacing-4 0;
      color: $text-color;
    }

    ul {
      margin: 0;
      padding-left: $spacing-5;
      color: $gray-600;
    }

    li {
      margin-bottom: $spacing-2;
      line-height: 1.5;
    }
  }

  .features {
    margin-top: $spacing-16;
  }

  .features h2 {
    text-align: center;
    font-size: $font-size-3xl;
    margin-bottom: $spacing-8;
    color: $text-color;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: $spacing-6;
    margin-top: $spacing-8;
  }

  .feature-card {
    background: white;
    padding: $spacing-6;
    border-radius: $border-radius-lg;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    border: 1px solid $gray-200;
    transition: all $transition-normal;

    &:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 24px -4px rgba(0, 0, 0, 0.1);
    }

    h3 {
      font-size: $font-size-xl;
      margin: 0 0 $spacing-3 0;
      color: $text-color;
    }

    p {
      color: $gray-600;
      margin: 0;
      line-height: 1.6;
    }
  }
</style>